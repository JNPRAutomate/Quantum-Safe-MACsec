{# ------------------------------- #}
{# QFX MACsec STATIC CONFIG       #}
{# ------------------------------- #}

{% set ca = device.macsec.ca_name | default("CA1") %}
{% set cipher = platform.macsec.cipher | default("gcm-aes-xpn-256") %}
{% set ckn = device.macsec.ckn %}
{% set cak = device.macsec.cak %}

# -------------------------------
# Connectivity Association
# -------------------------------

set security macsec connectivity-association {{ ca }} cipher-suite {{ cipher }}
set security macsec connectivity-association {{ ca }} security-mode static-cak
set security macsec connectivity-association {{ ca }} replay-protect

# STATIC KEYS
set security macsec connectivity-association {{ ca }} pre-shared-key ckn {{ ckn }}
set security macsec connectivity-association {{ ca }} pre-shared-key cak {{ cak }}